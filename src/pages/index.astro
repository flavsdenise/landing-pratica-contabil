---
const whatsappNumber = "5585996802744";
const whatsappMessage = "Vim pelo Instagram e quero saber mais informações dos seus serviços";
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
const instagramHandle = "@somospraticacontabil";
const instagramHref = "https://instagram.com/somospraticacontabil";
const companyName = "Prática Assessoria em Negócios";

const services = [
	"Contabilidade Operacional",
	"Contabilidade Gerencial",
	"Contabilidade Consultiva e Personalizada",
	"BPO Financeiro",
	"Controle Societário",
	"Visita Técnica",
	"Contabilidade Eleitoral e Partidária",
	"Treinamentos e Palestras Empresariais",
];

// Destaques derivados do texto real do cliente (consultoria, contabilidade, finanças)
const highlights = [
	{
		title: "Consultoria empresarial",
		text: "Estratégias personalizadas para decisões mais assertivas e crescimento sustentável.",
	},
	{
		title: "Serviços de contabilidade",
		text: "Rotina contábil completa, organizada e sempre em dia com as obrigações.",
	},
	{
		title: "Assessoria financeira",
		text: "Saúde financeira e administrativa cuidada de perto, com comprometimento e qualidade.",
	},
];
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Assessoria Empresarial • Serviços Contábeis e Financeiros. Entre em contato e tenha um serviço personalizado para o crescimento da sua empresa." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
		<title>{companyName}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="container header-inner">
				<a href="#inicio" class="logo">
					<img src="/logo-pratica-header.png" alt={companyName} class="logo-img" />
				</a>
				<nav class="main-nav">
					<a href="#inicio">Início</a>
					<a href="#quem-somos">Quem Somos</a>
					<a href="#servicos">Serviços</a>
					<a href="#fale-conosco">Fale Conosco</a>
				</nav>
				<button class="nav-toggle" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-nav">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
			<nav class="mobile-nav" id="mobile-nav">
				<a href="#inicio">Início</a>
				<a href="#quem-somos">Quem Somos</a>
				<a href="#servicos">Serviços</a>
				<a href="#fale-conosco">Fale Conosco</a>
				<a class="mobile-cta" href={whatsappHref} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a>
			</nav>
		</header>

		<main>
			<section class="hero" id="inicio">
				<div class="container hero-grid">
					<div class="hero-copy">
						<span class="eyebrow reveal">Assessoria Empresarial • Contábil e Financeira</span>
						<h1 class="reveal" style="transition-delay: 80ms">
							Um serviço personalizado para o crescimento da sua empresa
						</h1>
						<p class="hero-lead reveal" style="transition-delay: 160ms">
							A Prática cuida da contabilidade, da consultoria e das finanças do seu
							negócio para que você tome decisões mais assertivas e cresça com segurança.
						</p>
						<div class="hero-actions reveal" style="transition-delay: 240ms">
							<a class="btn btn-primary btn-large" href={whatsappHref} target="_blank" rel="noopener noreferrer">
								Falar no WhatsApp
							</a>
						</div>
					</div>
					<div class="hero-media reveal" style="transition-delay: 200ms">
						<div class="hero-frame">
							<img src="/primeira-secao.jpg" alt="Escritório da Prática Assessoria em Negócios" />
						</div>
					</div>
				</div>
			</section>

			<section class="sobre" id="quem-somos">
				<div class="container sobre-grid">
					<div class="sobre-media reveal">
						<div class="sobre-frame">
							<img src="/foto-equipe3-clean.png" alt="Equipe da Prática Assessoria em Negócios" />
						</div>
					</div>
					<div class="sobre-copy">
						<span class="eyebrow reveal">Quem somos</span>
						<h2 class="reveal" style="transition-delay: 80ms">
							Especialistas em soluções completas para a sua empresa
						</h2>
						<p class="reveal" style="transition-delay: 140ms">
							A Prática Assessoria em Negócios ajuda empresários a melhorar sua gestão e
							impulsionar o crescimento dos seus negócios, sempre com comprometimento e
							qualidade.
						</p>
						<ul class="highlight-list">
							{highlights.map((h, i) => (
								<li class="reveal" style={`transition-delay: ${200 + i * 80}ms`}>
									<span class="highlight-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
											<path d="M5 12.5l4.5 4.5L19 7.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</span>
									<div>
										<strong>{h.title}</strong>
										<span>{h.text}</span>
									</div>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<section class="servicos" id="servicos">
				<div class="container">
					<div class="section-head">
						<span class="eyebrow reveal">Nossos serviços</span>
						<h2 class="reveal" style="transition-delay: 80ms">
							Tudo o que a sua empresa precisa, em um só lugar
						</h2>
					</div>
					<div class="servicos-grid">
						{services.map((service, i) => (
							<div class="servico-card reveal" style={`transition-delay: ${i * 60}ms`}>
								<p>{service}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!--
				SEÇÕES PENDENTES — aguardando conteúdo real do cliente antes de construir.
				Ver briefing, seção 7. Cada uma será destravada assim que o dado chegar:

				1. Barra de números
					 Precisa de: anos de mercado, empresas atendidas, prazo médio de abertura
					 de empresa, nota de satisfação.

				2. Diferenciais (grid de cards)
					 Precisa de: lista de diferenciais reais da Prática (não fornecidos ainda).

				3. Como funciona (3 passos)
					 Precisa de: descrição do processo real de atendimento/contratação.

				4. Prova social
					 Precisa de: depoimentos de clientes, se houver.

				5. FAQ
					 Precisa de: perguntas frequentes reais sobre os serviços.

				Referência visual: accting-wcopilot.webflow.io (estilo clean/moderno).
			-->

			<section class="cta-final" id="fale-conosco">
				<div class="container cta-final-inner">
					<h2 class="reveal">Pronto para dar o próximo passo na sua empresa?</h2>
					<p class="reveal" style="transition-delay: 80ms">
						Fale com a nossa equipe pelo WhatsApp e receba um atendimento personalizado.
					</p>
					<a class="btn btn-large cta-btn reveal" style="transition-delay: 160ms" href={whatsappHref} target="_blank" rel="noopener noreferrer">
						Falar no WhatsApp
					</a>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<div class="footer-brand">
					<img src="/logo-pratica-header.png" alt={companyName} class="footer-logo" />
				</div>
				<div class="footer-social">
					<a class="social-icon" href={whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
						<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.549 4.142 1.595 5.945L0 24l6.335-1.652a11.882 11.882 0 005.71 1.454h.006c6.585 0 11.946-5.359 11.949-11.893a11.821 11.821 0 00-3.479-8.417z"/>
						</svg>
					</a>
					<a class="social-icon" href={instagramHref} target="_blank" rel="noopener noreferrer" aria-label={`Instagram ${instagramHandle}`}>
						<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0m0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324M12 16a4 4 0 110-8 4 4 0 010 8m6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881"/>
						</svg>
					</a>
					<!-- TODO: adicionar endereço quando o cliente enviar -->
				</div>
			</div>
			<div class="container">
				<p class="footer-copy">&copy; {new Date().getFullYear()} {companyName}. Todos os direitos reservados.</p>
			</div>
		</footer>

		<script>
			const header = document.querySelector(".site-header");
			const updateHeader = () => {
				header?.classList.toggle("is-scrolled", window.scrollY > 20);
			};
			updateHeader();
			window.addEventListener("scroll", updateHeader, { passive: true });

			const navToggle = document.querySelector(".nav-toggle");
			const mobileNav = document.querySelector(".mobile-nav");
			navToggle?.addEventListener("click", () => {
				const isOpen = mobileNav?.classList.toggle("is-open");
				navToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
			});
			mobileNav?.querySelectorAll("a").forEach((link) => {
				link.addEventListener("click", () => {
					mobileNav.classList.remove("is-open");
					navToggle?.setAttribute("aria-expanded", "false");
				});
			});

			// Rolagem dos links de menu: centraliza a seção na tela quando ela cabe;
			// caso contrário, alinha o topo logo abaixo do header.
			const anchorLinks = document.querySelectorAll('a[href^="#"]');
			anchorLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					const id = link.getAttribute("href");
					if (!id || id === "#") return;
					const target = document.querySelector(id);
					if (!target) return;
					e.preventDefault();
					const headerH = header ? header.offsetHeight : 74;
					const gap = 16;
					const avail = window.innerHeight - headerH;
					const absTop = target.getBoundingClientRect().top + window.scrollY;
					let dest;
					if (target.offsetHeight <= avail - gap) {
						dest = absTop - headerH - (avail - target.offsetHeight) / 2;
					} else {
						dest = absTop - headerH - gap;
					}
					window.scrollTo({ top: Math.max(0, dest), behavior: "smooth" });
					history.replaceState(null, "", id);
				});
			});

			const revealEls = document.querySelectorAll(".reveal");
			if ("IntersectionObserver" in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								io.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
				);
				revealEls.forEach((el) => io.observe(el));
			} else {
				revealEls.forEach((el) => el.classList.add("is-visible"));
			}
		</script>
	</body>
</html>

<style>
	:root {
		--color-primary: #225F71;
		--color-accent: #2FA695;
		--color-gradient: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		--color-ink: #0f2a33;
		--color-text: #2c4a53;
		--color-text-muted: #5c7880;
		--color-bg: #ffffff;
		--color-bg-soft: #f1f8f6;
		--color-border: #e2edeb;
		--radius: 20px;
		--radius-sm: 14px;
		--shadow-sm: 0 2px 12px rgba(15, 42, 51, 0.06);
		--shadow-md: 0 18px 40px rgba(15, 42, 51, 0.10);
		--font-body: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
		--font-display: "Plus Jakarta Sans", "Inter", system-ui, sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: 90px;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}

	body {
		font-family: var(--font-body);
		color: var(--color-text);
		background: var(--color-bg);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	.container {
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	h1,
	h2 {
		font-family: var(--font-display);
		color: var(--color-ink);
		letter-spacing: -0.02em;
		margin: 0;
	}

	.eyebrow {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 0.9rem;
	}

	/* Scroll reveal */
	.reveal {
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	.reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	/* Header */
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
	}

	.site-header.is-scrolled {
		border-bottom-color: var(--color-border);
		box-shadow: 0 4px 20px rgba(15, 42, 51, 0.05);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		height: 74px;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
	}

	.logo-img {
		height: 46px;
		width: auto;
		display: block;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-left: auto;
	}

	.main-nav a {
		color: var(--color-text);
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95rem;
		transition: color 0.2s ease;
	}

	.main-nav a:hover {
		color: var(--color-primary);
	}

	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		width: 40px;
		height: 40px;
		border: none;
		background: transparent;
		cursor: pointer;
		padding: 0;
	}

	.nav-toggle span {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--color-ink);
		border-radius: 2px;
		transition: transform 0.25s ease, opacity 0.25s ease;
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.mobile-nav {
		display: none;
	}

	@media (max-width: 860px) {
		.main-nav {
			display: none;
		}

		.nav-toggle {
			display: flex;
		}

		.mobile-nav {
			position: absolute;
			top: 74px;
			left: 0;
			right: 0;
			flex-direction: column;
			background: #fff;
			border-bottom: 1px solid var(--color-border);
			box-shadow: var(--shadow-md);
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.3s ease;
		}

		.mobile-nav.is-open {
			display: flex;
			max-height: 420px;
		}

		.mobile-nav a {
			color: var(--color-text);
			text-decoration: none;
			font-weight: 500;
			padding: 1rem 1.5rem;
			border-top: 1px solid var(--color-border);
		}

		.mobile-nav a:hover {
			color: var(--color-primary);
		}

		.mobile-nav .mobile-cta {
			color: var(--color-primary);
			font-weight: 600;
		}
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		font-weight: 600;
		font-family: var(--font-body);
		border-radius: 999px;
		padding: 0.6rem 1.35rem;
		font-size: 0.95rem;
		transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.2s ease;
	}

	.btn-primary {
		background: var(--color-gradient);
		color: #fff;
		box-shadow: 0 6px 18px rgba(34, 95, 113, 0.22);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 24px rgba(34, 95, 113, 0.3);
	}

	.btn-large {
		padding: 0.95rem 2.1rem;
		font-size: 1.05rem;
	}

	/* Hero */
	.hero {
		padding: calc(74px + 4.5rem) 0 5rem;
		background:
			radial-gradient(120% 120% at 80% 0%, rgba(47, 166, 149, 0.08), transparent 55%),
			var(--color-bg);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: 3.5rem;
		align-items: center;
	}

	.hero h1 {
		font-size: clamp(2.1rem, 4.6vw, 3.3rem);
		line-height: 1.08;
		margin-bottom: 1.25rem;
	}

	.hero-lead {
		font-size: 1.12rem;
		color: var(--color-text-muted);
		max-width: 30rem;
		margin: 0 0 2rem;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.link-instagram {
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 500;
	}

	.link-instagram:hover {
		color: var(--color-primary);
	}

	.hero-frame {
		position: relative;
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--shadow-md);
		aspect-ratio: 5 / 4;
	}

	.hero-frame img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 60%;
		display: block;
	}

	/* Quem somos */
	.sobre {
		padding: 6rem 0;
	}

	.sobre-grid {
		display: grid;
