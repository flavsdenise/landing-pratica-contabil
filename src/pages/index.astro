		<script>
			const header = document.querySelector(".site-header");
			const updateHeader = () => {
				header?.classList.toggle("is-scrolled", window.scrollY > 20);
			};
			updateHeader();
			window.addEventListener("scroll", updateHeader, { passive: true });

			const navToggle = document.querySelector(".nav-toggle");
			const mobileNav = document.querySelector(".mobile-nav");
			navToggle?.addEventListener("click", () => {
				const isOpen = mobileNav?.classList.toggle("is-open");
				navToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
			});
			mobileNav?.querySelectorAll("a").forEach((link) => {
				link.addEventListener("click", () => {
					mobileNav.classList.remove("is-open");
					navToggle?.setAttribute("aria-expanded", "false");
				});
			});

			// Rolagem dos links de menu: centraliza a seção na tela quando ela cabe;
			// caso contrário, alinha o topo logo abaixo do header.
			const anchorLinks = document.querySelectorAll('a[href^="#"]');
			anchorLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					const id = link.getAttribute("href");
					if (!id || id === "#") return;
					const target = document.querySelector(id);
					if (!target) return;
					e.preventDefault();
					const headerH = header ? header.offsetHeight : 74;
					const gap = 16;
					const avail = window.innerHeight - headerH;
					const absTop = target.getBoundingClientRect().top + window.scrollY;
					let dest;
					if (target.offsetHeight <= avail - gap) {
						dest = absTop - headerH - (avail - target.offsetHeight) / 2;
					} else {
						dest = absTop - headerH - gap;
					}
					window.scrollTo({ top: Math.max(0, dest), behavior: "smooth" });
					history.replaceState(null, "", id);
				});
			});

			// Barra social flutuante: no mobile, o gatilho abre/fecha as opções.
			const socialRail = document.querySelector(".social-rail");
			const railToggle = document.querySelector(".rail-toggle");
			railToggle?.addEventListener("click", () => {
				const isOpen = socialRail?.classList.toggle("is-open");
				railToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
				railToggle.setAttribute("aria-label", isOpen ? "Fechar contatos" : "Abrir contatos");
			});

			// Efeito de digitação no trecho destacado do título do hero.
			const typedEl = document.getElementById("hero-typed");
			const caretEl = document.getElementById("hero-caret");
			if (typedEl) {
				const fullText = typedEl.textContent || "";
				const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
				if (prefersReduced) {
					typedEl.textContent = fullText;
				} else {
					typedEl.textContent = "";
					let i = 0;
					const type = () => {
						typedEl.textContent = fullText.slice(0, i + 1);
						i++;
						if (i < fullText.length) {
							setTimeout(type, 95);
						} else if (caretEl) {
							setTimeout(() => caretEl.classList.add("is-done"), 1200);
						}
					};
					setTimeout(type, 550);
				}
			}

			// Cards de serviço: clicar expande/recolhe a descrição.
			const serviceCards = document.querySelectorAll(".servico-card");
			serviceCards.forEach((card) => {
				card.addEventListener("click", () => {
					const isOpen = card.getAttribute("aria-expanded") === "true";
					card.setAttribute("aria-expanded", isOpen ? "false" : "true");
				});
			});

			const revealEls = document.querySelectorAll(".reveal");
			if ("IntersectionObserver" in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								io.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
				);
				revealEls.forEach((el) => io.observe(el));
			} else {
				revealEls.forEach((el) => el.classList.add("is-visible"));
			}
		</script>
	</body>
</html>

